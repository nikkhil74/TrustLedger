# =============================================================================
# TrustLedger — Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# Database
DATABASE_URL=postgresql://trustledger:trustledger@localhost:5432/trustledger

# Redis
REDIS_URL=redis://localhost:6379

# JWT Authentication
JWT_SECRET=change-this-to-a-random-256-bit-secret
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# Score Engine (internal)
SCORE_ENGINE_URL=http://localhost:5000

# Blockchain — Polygon
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology
CHAIN_ID=80002
SCORE_ORACLE_PRIVATE_KEY=
POLYGONSCAN_API_KEY=

# Smart Contract Addresses (set after deployment)
TRUSTLEDGER_SCORE_ADDRESS=
BEHAVIOR_TOKEN_ADDRESS=
SCORE_VERIFIER_ADDRESS=

# Account Aggregator (Setu / Finvu)
AA_CLIENT_ID=
AA_CLIENT_SECRET=
AA_BASE_URL=https://fiu-uat.setu.co

# Aadhaar eKYC (via KSA partner)
UIDAI_KSA_CLIENT_ID=
UIDAI_KSA_CLIENT_SECRET=

# Twilio / WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# Covalent API
COVALENT_API_KEY=

# The Graph
THE_GRAPH_API_KEY=

# IPFS / Pinata
PINATA_API_KEY=
PINATA_SECRET_KEY=

# Frontend (public)
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WALLETCONNECT_ID=
NEXT_PUBLIC_CHAIN_ID=80002
NEXT_PUBLIC_ZK_ENABLED=false

# API Server
PORT=4000
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=info
